#!/usr/bin/env bash
set -Eeuo pipefail

PROFILE_FILE="/etc/ib-power-profile"

reexec_sudo() {
if [[ $EUID -ne 0 ]]; then
exec sudo "$0" "$@"
fi
}

reset_system() {

```
if command -v cpupower >/dev/null 2>&1; then
    cpupower frequency-set -g powersave >/dev/null 2>&1 || true
fi

if command -v x86_energy_perf_policy >/dev/null 2>&1; then
    x86_energy_perf_policy balance-performance >/dev/null 2>&1 || true
fi

if [[ -w /sys/devices/system/cpu/intel_pstate/no_turbo ]]; then
    echo 0 > /sys/devices/system/cpu/intel_pstate/no_turbo
fi

if [[ -w /sys/kernel/mm/transparent_hugepage/enabled ]]; then
    echo always > /sys/kernel/mm/transparent_hugepage/enabled
fi

if [[ -w /sys/kernel/mm/transparent_hugepage/defrag ]]; then
    echo always > /sys/kernel/mm/transparent_hugepage/defrag
fi

for f in /sys/devices/system/cpu/cpu*/cpuidle/state*/disable; do
    [[ -w "$f" ]] && echo 0 > "$f"
done
```

}

apply_powersaver() {

```
cpupower frequency-set -g powersave >/dev/null 2>&1 || true

if command -v x86_energy_perf_policy >/dev/null 2>&1; then
    x86_energy_perf_policy power >/dev/null 2>&1 || true
fi
```

}

apply_balanced() {

```
cpupower frequency-set -g powersave >/dev/null 2>&1 || true

if command -v x86_energy_perf_policy >/dev/null 2>&1; then
    x86_energy_perf_policy balance-performance >/dev/null 2>&1 || true
fi
```

}

apply_performance() {

```
cpupower frequency-set -g performance >/dev/null 2>&1 || true

if command -v x86_energy_perf_policy >/dev/null 2>&1; then
    x86_energy_perf_policy balance-performance >/dev/null 2>&1 || true
fi
```

}

apply_maximum() {

```
cpupower frequency-set -g performance >/dev/null 2>&1 || true

if command -v x86_energy_perf_policy >/dev/null 2>&1; then
    x86_energy_perf_policy performance >/dev/null 2>&1 || true
fi

if [[ -w /sys/devices/system/cpu/intel_pstate/no_turbo ]]; then
    echo 0 > /sys/devices/system/cpu/intel_pstate/no_turbo
fi

if [[ -w /sys/kernel/mm/transparent_hugepage/enabled ]]; then
    echo never > /sys/kernel/mm/transparent_hugepage/enabled
fi

if [[ -w /sys/kernel/mm/transparent_hugepage/defrag ]]; then
    echo never > /sys/kernel/mm/transparent_hugepage/defrag
fi

for f in /sys/devices/system/cpu/cpu*/cpuidle/state*/disable; do
    [[ -w "$f" ]] && echo 1 > "$f"
done
```

}

set_profile() {

```
local profile="$1"

reset_system

case "$profile" in

    powersaver)
        apply_powersaver
        ;;

    balanced)
        apply_balanced
        ;;

    performance)
        apply_performance
        ;;

    maximum)
        apply_maximum
        ;;

    *)
        echo "Unknown profile"
        exit 1
        ;;
esac

echo "$profile" > "$PROFILE_FILE"

echo "Applied profile: $profile"
```

}

restore_profile() {

```
if [[ -f "$PROFILE_FILE" ]]; then
    set_profile "$(cat "$PROFILE_FILE")"
else
    set_profile balanced
fi
```

}

current_profile() {

```
if [[ -f "$PROFILE_FILE" ]]; then
    cat "$PROFILE_FILE"
else
    echo balanced
fi
```

}

status_profile() {

```
echo
echo "Profile:"
current_profile

echo

cpupower frequency-info 2>/dev/null | grep governor || true

echo
```

}

case "${1:-}" in

```
set)
    reexec_sudo "$@"
    set_profile "${2:-balanced}"
    ;;

restore)
    reexec_sudo "$@"
    restore_profile
    ;;

current)
    current_profile
    ;;

status)
    status_profile
    ;;

*)
    echo
    echo "Usage:"
    echo "ib-power-mode set powersaver"
    echo "ib-power-mode set balanced"
    echo "ib-power-mode set performance"
    echo "ib-power-mode set maximum"
    echo "ib-power-mode restore"
    echo "ib-power-mode current"
    echo "ib-power-mode status"
    echo
    exit 1
    ;;
```

esac
